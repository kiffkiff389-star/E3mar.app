  const lines=s.lines||[];
  lines.forEach(l=>{
    addSaleRow();
    const id='sr_'+saleRowCount;
    document.getElementById(id+'_name').value=l.name;
    document.getElementById(id+'_qty').value=l.qty;
    document.getElementById(id+'_price').value=l.price;
    calcSaleRow(id);
  });
  updateSaleTotal();
  // Change modal title and save button
  document.querySelector('#mSale .modal-title').textContent='✏️ تعديل الفاتورة '+s.id;
  document.querySelector('#mSale .modal-btns .btn-primary').textContent='💾 حفظ التعديل';
  document.querySelector('#mSale .modal-btns .btn-primary').onclick=submitEditSale;
  openModal('mSale');
}
function submitEditSale(){
  if(editSaleIdx===null){saveSale();return;}
  const s=sales[editSaleIdx];
  const cust=document.getElementById('s_cust').value||s.cust;
  const dueDate=document.getElementById('s_due').value||'';
  const lines=[]; let grand=0; let hasError=false;
  document.querySelectorAll('#saleItemRows .invoice-item-row').forEach(row=>{
    const rowId=row.id;
    const name=document.getElementById(rowId+'_name')?.value.trim()||'';
    const qty=parseFloat(document.getElementById(rowId+'_qty')?.value)||0;
    const price=parseFloat(document.getElementById(rowId+'_price')?.value)||0;
    if(!name||qty<=0){hasError=true;return;}
    grand+=qty*price; lines.push({name,qty,price,sub:qty*price});
  });
  if(!lines.length||hasError){alert('⚠️ أدخل اسم المادة والكمية');return;}
  const paid=parseFloat(document.getElementById('s_paid').value)||s.paid;
  // Restore old stock then deduct new
  const oldLines=s.lines||[];
  oldLines.forEach(l=>{const idx=items.findIndex(it=>it.name===l.name);if(idx>=0)items[idx].qty+=l.qty;});
  lines.forEach(l=>{const idx=items.findIndex(it=>it.name===l.name);if(idx>=0)items[idx].qty-=l.qty;});
  sales[editSaleIdx]={...s,cust,lines,total:grand,paid,dueDate,date:document.getElementById('s_date').value.replace(/-/g,'/')};
  saveAll(); addAudit('sale','تعديل فاتورة '+s.id); renderSales(); renderItems();
  closeModal('mSale'); editSaleIdx=null;
  // Reset modal to add mode
  document.querySelector('#mSale .modal-title').textContent='🧾 فاتورة مبيعات جديدة';
  document.querySelector('#mSale .modal-btns .btn-primary').textContent='💾 حفظ الفاتورة';
  document.querySelector('#mSale .modal-btns .btn-primary').onclick=saveSale;
  alert('✅ تم تعديل الفاتورة بنجاح!');
}

