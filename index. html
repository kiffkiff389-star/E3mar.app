let payIdx=null;
function openPayModal(idx){
  payIdx=idx; const s=sales[idx]; const rem=s.total-s.paid;
  document.getElementById('pay_cust').textContent=s.cust;
  document.getElementById('pay_total').textContent=N(s.total)+' دينار';
  document.getElementById('pay_prev').textContent=N(s.paid)+' دينار';
  document.getElementById('pay_rem').textContent=N(rem)+' دينار';
  document.getElementById('pay_amount').value='';
  document.getElementById('pay_after').textContent=N(rem)+' دينار';
  openModal('mPay');
}
function calcPayRemain(){
  if(payIdx===null) return;
  const s=sales[payIdx]; const rem=s.total-s.paid;
  const amt=parseFloat(document.getElementById('pay_amount').value)||0;
  const after=Math.max(rem-amt,0);
  const el=document.getElementById('pay_after');
  el.textContent=N(after)+' دينار';
  el.style.color=after===0?'var(--success)':after<rem?'var(--warning)':'var(--danger)';
}
function submitPay(){
  if(payIdx===null) return;
  const s=sales[payIdx]; const rem=s.total-s.paid;
  const amt=parseFloat(document.getElementById('pay_amount').value)||0;
  if(amt<=0){alert('⚠️ أدخل مبلغ صحيح');return;}
  if(amt>rem){alert('⚠️ المبلغ أكبر من المتبقي');return;}
  sales[payIdx].paid+=amt;
  saveAll();
  addAudit('payment','دفعة '+N(amt)+' دينار من '+s.cust+' للفاتورة '+s.id);
  if(debtFilterOn) showDebtOnly(); else renderSales();
  closeModal('mPay');
  const newRem=s.total-sales[payIdx].paid;
  alert(newRem<=0?'✅ تم التسديد الكامل للفاتورة '+s.id:'✅ تم تسجيل الدفعة. المتبقي: '+N(newRem)+' دينار');
}

let purchPayIdx=null;
function openPurchPayModal(i){
  purchPayIdx=i; const p=purchases[i]; const paid=p.paid||0; const rem=p.total-paid;
  document.getElementById('ppay_supp').textContent=p.supp;
  document.getElementById('ppay_total').textContent=N(p.total)+' دينار';
  document.getElementById('ppay_prev').textContent=N(paid)+' دينار';
  document.getElementById('ppay_rem').textContent=N(rem)+' دينار';
  document.getElementById('ppay_amount').value='';
  document.getElementById('ppay_after').textContent=N(rem)+' دينار';
  openModal('mPurchPay');
}
function calcPurchPayRemain(){
  if(purchPayIdx===null) return;
  const p=purchases[purchPayIdx]; const paid=p.paid||0; const rem=p.total-paid;
  const amt=parseFloat(document.getElementById('ppay_amount').value)||0;
  const after=Math.max(rem-amt,0);
  const el=document.getElementById('ppay_after');
  el.textContent=N(after)+' دينار';
  el.style.color=after===0?'var(--success)':after<rem?'var(--warning)':'var(--danger)';
}
function submitPurchPay(){
  if(purchPayIdx===null) return;
  const p=purchases[purchPayIdx]; const paid=p.paid||0; const rem=p.total-paid;
  const amt=parseFloat(document.getElementById('ppay_amount').value)||0;
  if(amt<=0){alert('⚠️ أدخل مبلغ صحيح');return;}
  if(amt>rem){alert('⚠️ المبلغ أكبر من المتبقي');return;}
  purchases[purchPayIdx].paid=paid+amt;
  if(purchases[purchPayIdx].paid>=purchases[purchPayIdx].total) purchases[purchPayIdx].status='مستلمة';
  saveAll(); addAudit('payment','دفعة '+N(amt)+' دينار للمورد '+p.supp);
  renderPurch(); closeModal('mPurchPay');
  const newRem=p.total-purchases[purchPayIdx].paid;
  alert(newRem<=0?'✅ تم التسديد الكامل للمورد '+p.supp:'✅ تم تسجيل الدفعة. المتبقي: '+N(newRem)+' دينار');
}

