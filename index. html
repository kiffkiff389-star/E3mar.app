function handleImportDrop(e){
  e.preventDefault();
  const file = e.dataTransfer.files[0];
  if(file) processBackupFile(file);
}

function handleImport(e){
  const file = e.target.files[0];
  if(file) processBackupFile(file);
  e.target.value = '';
}

function processBackupFile(file){
  if(!file.name.endsWith('.json')){
    showImportStatus('❌ يجب اختيار ملف JSON فقط', 'danger');
    return;
  }
  const reader = new FileReader();
  reader.onload = function(ev){
    try {
      const data = JSON.parse(ev.target.result);
      if(!data.sales && !data.items && !data.customers){
        showImportStatus('❌ الملف غير صالح — ليس ملف نسخة احتياطية', 'danger');
        return;
      }
      const count = (data.sales||[]).length + (data.items||[]).length + (data.customers||[]).length;
      if(!confirm('🔄 سيتم استيراد البيانات التالية:\n' +
        '• ' + (data.sales||[]).length + ' فاتورة مبيعات\n' +
        '• ' + (data.purchases||[]).length + ' فاتورة شراء\n' +
        '• ' + (data.items||[]).length + ' صنف في المخزن\n' +
        '• ' + (data.customers||[]).length + ' عميل\n' +
        '• ' + (data.suppliers||[]).length + ' مورد\n\n' +
        'تاريخ النسخة: ' + (data.exportDate||'غير معروف') + '\n\n' +
        '⚠️ سيتم استبدال البيانات الحالية. هل تريد المتابعة؟')) return;

      // Restore all data
      if(data.sales)      { sales=data.sales;            save('sales',sales); }
      if(data.purchases)  { purchases=data.purchases;     save('purchases',purchases); }
      if(data.items)      { items=data.items;              save('items',items); }
      if(data.customers)  { customers=data.customers;      save('customers',customers); }
      if(data.suppliers)  { suppliers=data.suppliers;      save('suppliers',suppliers); }
      if(data.employees)  { employees=data.employees;      save('employees',employees); }
      if(data.returns)    { returns=data.returns;          save('returns',returns); }
      if(data.transports) { transports=data.transports;    save('transports',transports); }
      if(data.auditLog)   { auditLog=data.auditLog;        save('auditLog',auditLog); }
      if(data.appUsers)   { appUsers=data.appUsers;        save('appUsers',appUsers); }
      if(data.appConfig)  { appConfig=data.appConfig;      save('appConfig',appConfig); }
      if(data.invCounter) { invCounter=data.invCounter;    save('invCounter',invCounter); }
      if(data.lowThreshold!==undefined){ lowThreshold=data.lowThreshold; save('lowThreshold',lowThreshold); }

      addAudit('login','✅ تم استيراد نسخة احتياطية — '+count+' سجل');
      renderAll();
      showImportStatus('✅ تم استيراد البيانات بنجاح! (' + count + ' سجل)', 'success');
