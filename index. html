// ── SALES CHART ──
// ══════════════════════════════════════════
function renderSalesChart(){
  const wrap=document.getElementById('salesChartWrap'); if(!wrap) return;
  const months=[];
  for(let i=5;i>=0;i--){
    const d=new Date(); d.setMonth(d.getMonth()-i);
    months.push({label:d.toLocaleDateString('ar-IQ',{month:'short'}), key:(d.getFullYear()+'-'+(String(d.getMonth()+1).padStart(2,'0')))});
  }
  const data=months.map(m=>{
    const total=sales.filter(s=>s.date.substring(0,7).replace(/\//g,'-')===m.key||s.date.replace(/\//g,'-').startsWith(m.key)).reduce((s,x)=>s+x.total,0);
    return {label:m.label,val:total};
  });
  const maxVal=Math.max(...data.map(d=>d.val),1);
  const colors=['#c8102e','#e8c56d','#10b981','#3b82f6','#8b5cf6','#f59e0b'];
  wrap.innerHTML=`
    <div class="chart-bar-wrap">
      ${data.map((d,i)=>`
        <div class="chart-bar" style="height:${Math.max(d.val/maxVal*100,2)}%;background:${colors[i%colors.length]};" title="${d.label}: ${N(d.val)} دينار">
          ${d.val>0?`<div class="bar-tip">${N(d.val)}</div>`:''}
        </div>`).join('')}
    </div>
    <div class="chart-labels">${data.map(d=>`<div class="chart-label">${d.label}</div>`).join('')}</div>`;
}

