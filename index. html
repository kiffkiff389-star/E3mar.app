function renderRptInventory(){
  const tbl=document.getElementById('rptItemsTbl'); if(!tbl) return;
  const low=lowThreshold;
  const catF=document.getElementById('rpt-cat-filter')?.value||'';
  const stF=document.getElementById('rpt-status-filter')?.value||'';
  let display=items;
  if(catF) display=display.filter(it=>it.cat===catF);
  if(stF==='low') display=display.filter(it=>it.qty>0&&it.qty<=low);
  else if(stF==='out') display=display.filter(it=>it.qty<=0);
  else if(stF==='ok') display=display.filter(it=>it.qty>low);
  const totalVal=display.reduce((s,it)=>s+it.qty*it.buy,0);
  tbl.innerHTML=display.length?display.map(it=>{
    const invVal=it.qty*it.buy;
    const margin=it.buy&&it.sell?Math.round((it.sell-it.buy)/it.sell*100):0;
    return `<tr><td>${it.code}</td><td style="font-weight:700">${it.name}</td><td>${it.cat}</td>
      <td style="font-weight:800;color:${it.qty<=0?'var(--danger)':it.qty<=low?'var(--warning)':'var(--success)'}">${it.qty}</td>
      <td>${it.unit}</td><td>${N(it.buy)}</td><td>${N(it.sell)}</td>
      <td>${marginBadge(it.buy,it.sell)}</td>
      <td style="font-weight:700">${N(invVal)}</td>
      <td>${itemBadge(it.qty)}</td></tr>`;}).join('')
  :'<tr><td colspan="10" style="text-align:center;padding:24px;color:var(--light)">لا توجد بيانات</td></tr>';
  const footer=document.getElementById('rpt-inv-footer');
  if(footer) footer.innerHTML=`<span>📦 عدد الأصناف: <strong>${display.length}</strong></span>
    <span>💰 قيمة المخزون: <strong style="color:var(--primary)">${N(totalVal)} دينار</strong></span>
    <span>🚫 النافد: <strong style="color:var(--danger)">${display.filter(it=>it.qty<=0).length}</strong></span>
    <span>⚠️ المنخفض: <strong style="color:var(--warning)">${display.filter(it=>it.qty>0&&it.qty<=low).length}</strong></span>`;
}

function renderRptDebts(){
  const {from,to}=getDateFilter();
  const tbl=document.getElementById('rptDebtsTbl'); if(!tbl) return;
  const debts=sales.filter(s=>s.total-s.paid>0&&inDateRange(s.date,from,to));
  const totalDebt=debts.reduce((s,x)=>s+(x.total-x.paid),0);
  tbl.innerHTML=debts.length?debts.map(s=>{
