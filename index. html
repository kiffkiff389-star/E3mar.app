let itemFilterMode=null;

function updateLowThreshold(){
  const v=parseInt(document.getElementById('lowThresholdInput').value)||100;
  lowThreshold=v; save('lowThreshold',v); renderItems();
}
function initLowThresholdInput(){ const el=document.getElementById('lowThresholdInput'); if(el) el.value=lowThreshold; }

function toggleItemFilter(mode){
  itemFilterMode=itemFilterMode===mode?null:mode;
  ['iLowCard','iOutCard'].forEach(id=>{ const el=document.getElementById(id); if(el){el.style.background='';el.style.borderRightColor='';} });
  document.getElementById('iLowLabel').style.display='none';
  document.getElementById('iOutLabel').style.display='none';
  if(itemFilterMode==='low'){ const c=document.getElementById('iLowCard'); c.style.background='#fef9c3';c.style.borderRightColor='var(--warning)';document.getElementById('iLowLabel').style.display='block'; }
  else if(itemFilterMode==='out'){ const c=document.getElementById('iOutCard'); c.style.background='#fee2e2';c.style.borderRightColor='var(--danger)';document.getElementById('iOutLabel').style.display='block'; }
  renderItems();
}

function renderItems(){
  const tbl=document.getElementById('itemTbl');
  const cards=document.getElementById('itemCards');
  tbl.innerHTML=''; cards.innerHTML='';
  const low=lowThreshold;
  let display=items;
  if(itemFilterMode==='low') display=items.filter(it=>it.qty>0&&it.qty<=low);
  else if(itemFilterMode==='out') display=items.filter(it=>it.qty<=0);
  if(!display.length){tbl.innerHTML='<tr><td colspan="11" style="text-align:center;padding:24px;color:var(--light)">لا توجد بيانات</td></tr>';cards.innerHTML='<div class="empty"><div class="empty-icon">📭</div><p>لا توجد بيانات</p></div>';updateItemStats();return;}
  display.forEach(it=>{
    const i=items.indexOf(it);
    const rowStyle=it.qty<=0?'background:#fff8f8;':it.qty<=low?'background:#fffbeb;':'';
    const invVal=it.qty*it.buy;
    const margin=it.buy&&it.sell?Math.round((it.sell-it.buy)/it.sell*100):0;
    tbl.innerHTML+=`<tr style="${rowStyle}">
      <td>${it.code}</td><td style="font-weight:700">${it.name}</td><td>${it.cat}</td><td>${it.unit}</td>
      <td style="font-weight:800;color:${it.qty<=0?'var(--danger)':it.qty<=low?'var(--warning)':'var(--success)'}">${it.qty}</td>
