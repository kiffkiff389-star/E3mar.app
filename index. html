function N(n){return Number(n).toLocaleString('en-US');}
function fmt(n){return Number(n).toLocaleString('en-US');}

function statusBadge(paid,total){
  const r=total-paid;
  if(r<=0) return '<span class="badge badge-success">مدفوعة</span>';
  if(paid>0) return '<span class="badge badge-warning">جزئية</span>';
  return '<span class="badge badge-danger">غير مدفوعة</span>';
}
function purchBadge(s){return s==='مستلمة'?'<span class="badge badge-success">مستلمة</span>':'<span class="badge badge-warning">جزئية</span>';}
function itemBadge(q){
  return q<=0 ? '<span class="badge badge-danger">نافد</span>'
       : q<=lowThreshold ? '<span class="badge badge-warning">منخفض</span>'
       : '<span class="badge badge-success">متوفر</span>';
}
function marginBadge(buy,sell){
  if(!buy||!sell) return '';
  const pct = Math.round((sell-buy)/sell*100);
  const cls = pct>=30?'margin-high':pct>=15?'margin-mid':'margin-low';
  return `<span class="margin-badge ${cls}">${pct}%</span>`;
}
function dueBadge(dueDate){
  if(!dueDate) return '';
  const d = new Date(dueDate); const t = new Date();
  const diff = Math.ceil((d-t)/(1000*60*60*24));
  if(diff<0) return '<span class="badge badge-danger">متأخرة '+(Math.abs(diff))+' يوم</span>';
  if(diff<=7) return '<span class="badge badge-warning">تستحق خلال '+diff+' أيام</span>';
  return '<span class="badge badge-success">'+dueDate+'</span>';
}

// Invoice items summary
function saleItemsSummary(lines){
  if(!lines||!lines.length) return '-';
  return lines.map(l=>l.name).join('، ').substring(0,40)+(lines.length>1?'...':'');
}

