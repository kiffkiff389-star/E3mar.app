function getDateFilter(){
  const from=document.getElementById('rpt-from')?.value||'';
  const to=document.getElementById('rpt-to')?.value||'';
  return {from,to};
}
function inDateRange(dateStr,from,to){
  if(!from&&!to) return true;
  const d=dateStr.replace(/\//g,'-');
  if(from&&d<from) return false;
  if(to&&d>to) return false;
  return true;
}
function clearRptFilter(){ const f=document.getElementById('rpt-from'),t=document.getElementById('rpt-to'); if(f)f.value='';if(t)t.value='';renderReports(); }

function showRptPanel(name){
  document.querySelectorAll('.rpt-panel').forEach(el=>el.style.display='none');
  document.querySelectorAll('.rpt-tab').forEach(el=>el.classList.remove('active'));
  const panel=document.getElementById('rpt-panel-'+name); const tab=document.getElementById('rtab-'+name);
  if(panel) panel.style.display=''; if(tab) tab.classList.add('active');
  if(name==='inventory') renderRptInventory();
  else if(name==='debts') renderRptDebts();
  else if(name==='profit') renderRptProfit();
  else if(name==='returns_rpt') renderRptReturns();
  else if(name==='sales') renderRptSales();
  else if(name==='purchases') renderRptPurchases();
}

function renderReports(){
  const el1=document.getElementById('rpt-items'); if(!el1){setTimeout(renderReports,50);return;}
  const {from,to}=getDateFilter();
  const filtSales=sales.filter(s=>inDateRange(s.date,from,to));
  const filtPurch=purchases.filter(p=>inDateRange(p.date,from,to));
  const debtTotal=sales.reduce((s,x)=>s+(x.total-(x.paid||0)),0);
  el1.textContent=items.length;
  document.getElementById('rpt-sales-total').textContent=N(filtSales.reduce((s,x)=>s+x.total,0));
  document.getElementById('rpt-purch-total').textContent=N(filtPurch.reduce((s,x)=>s+x.total,0));
  document.getElementById('rpt-debt').textContent=N(debtTotal);
  const activeTab=document.querySelector('.rpt-tab.active');
  if(activeTab){ const name=activeTab.id.replace('rtab-','');showRptPanel(name); } else renderRptSales();
}

