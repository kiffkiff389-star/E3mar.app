  ['cred_old_pass','cred_new_pass','cred_confirm_pass'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('credChangeError').style.display='none';
  document.getElementById('credChangeSuccess').style.display='none';
  openModal('mChangeCredentials');
}

function saveCredentials(){
  const newUname = document.getElementById('cred_uname').value.trim();
  const oldPass  = document.getElementById('cred_old_pass').value;
  const newPass  = document.getElementById('cred_new_pass').value;
  const confPass = document.getElementById('cred_confirm_pass').value;
  const errEl    = document.getElementById('credChangeError');
  const okEl     = document.getElementById('credChangeSuccess');
  errEl.style.display='none'; okEl.style.display='none';

  if(!currentUser){ errEl.textContent='⚠️ يجب تسجيل الدخول أولاً'; errEl.style.display='block'; return; }
  if(!oldPass){ errEl.textContent='⚠️ يجب إدخال كلمة المرور الحالية'; errEl.style.display='block'; return; }

  // Verify current password
  if(currentUser.pass !== oldPass && !(oldPass==='1234' && currentUser.uname==='admin' && !currentUser.pass)){
    errEl.textContent='❌ كلمة المرور الحالية غير صحيحة'; errEl.style.display='block'; return;
  }

  // Validate new username uniqueness
  if(newUname && newUname !== currentUser.uname){
    if(appUsers.find(u=>u.uname===newUname)){
      errEl.textContent='⚠️ اسم المستخدم هذا مستخدم مسبقاً'; errEl.style.display='block'; return;
    }
  }

  // Validate new password match
  if(newPass && newPass !== confPass){
    errEl.textContent='❌ كلمة المرور الجديدة غير متطابقة'; errEl.style.display='block'; return;
  }

  // Apply changes
  const idx = appUsers.findIndex(u=>u.uname===currentUser.uname);
  if(idx<0){ errEl.textContent='❌ خطأ في العثور على المستخدم'; errEl.style.display='block'; return; }

  let changed = [];
  if(newUname && newUname !== currentUser.uname){
    appUsers[idx].uname = newUname;
    currentUser.uname   = newUname;
    changed.push('اسم المستخدم');
  }
  if(newPass){
    appUsers[idx].pass = newPass;
    currentUser.pass   = newPass;
    changed.push('كلمة المرور');
  }

  if(!changed.length){ errEl.textContent='⚠️ لم تقم بتغيير أي شيء'; errEl.style.display='block'; return; }

  save('appUsers', appUsers);
  addAudit('login','تغيير بيانات الدخول: '+changed.join(' و '));

  // Clear inputs
  ['cred_uname','cred_old_pass','cred_new_pass','cred_confirm_pass'].forEach(id=>document.getElementById(id).value='');
  okEl.textContent='✅ تم تغيير '+changed.join(' و ')+' بنجاح';
  okEl.style.display='block';
  setTimeout(()=>closeModal('mChangeCredentials'),1800);
}

