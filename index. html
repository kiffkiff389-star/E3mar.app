// ── Firebase Config ──
const firebaseConfig = {
  apiKey: "AIzaSyCAazYEN8QgFY00bMqd9UNvDvCfeBKnFyk",
  authDomain: "iemmar.firebaseapp.com",
  databaseURL: "https://iemmar-default-rtdb.firebaseio.com",
  projectId: "iemmar",
  storageBucket: "iemmar.firebasestorage.app",
  messagingSenderId: "506054234172",
  appId: "1:506054234172:web:a787323508dac2fcfa7339"
};

// ── Firebase Init ──
let db = null;
let firebaseReady = false;

function initFirebase(){
  return new Promise((resolve)=>{
    try{
      firebase.initializeApp(firebaseConfig);
      db = firebase.database();
      firebaseReady = true;
      console.log('✅ Firebase connected');
      resolve(true);
    } catch(e){
      console.warn('Firebase init failed:', e);
      resolve(false);
    }
  });
}

// ── Local Storage helpers ──
function load(key){ try{ const v=localStorage.getItem('aemaar_'+key); return v?JSON.parse(v):null; }catch(e){return null;} }

// ── Save: localStorage + Firebase ──
function save(key,val){
  try{ localStorage.setItem('aemaar_'+key, JSON.stringify(val)); }catch(e){}
  if(firebaseReady && db){
    db.ref('aemaar/'+key).set(val).catch(e=>console.warn('FB save error:',e));
  }
}

function saveAll(){
  save('sales',sales);
  save('purchases',purchases);
  save('items',items);
  save('customers',customers);
  save('suppliers',suppliers);
  save('employees',employees);
  save('invCounter',invCounter);
}

// ── Load all data from Firebase ──
async function loadFromFirebase(){
  if(!firebaseReady||!db) return false;
  try{
    const snap = await db.ref('aemaar').once('value');
    if(snap.exists()){
      const data = snap.val();
      const keys=['sales','purchases','items','customers','suppliers','employees',
                  'returns','transports','invCounter','appUsers','appConfig','auditLog','lowThreshold'];
      keys.forEach(k=>{
        if(data[k]!==undefined && data[k]!==null){
          localStorage.setItem('aemaar_'+k, JSON.stringify(data[k]));
        }
      });
      return true;
    }
  } catch(e){ console.warn('FB load error:',e); }
  return false;
}

// ── Real-time sync ──
function startRealtimeSync(){
  if(!firebaseReady||!db) return;
  db.ref('aemaar').on('value',(snap)=>{
    if(!snap.exists()) return;
    const data=snap.val();
    const keys=['sales','purchases','items','customers','suppliers','employees',
                'returns','transports','invCounter','appUsers','appConfig','auditLog','lowThreshold'];
    keys.forEach(k=>{
      if(data[k]!==undefined && data[k]!==null){
        localStorage.setItem('aemaar_'+k, JSON.stringify(data[k]));
      }
    });
  });
}

let sales      = load('sales')      ?? [];
let purchases  = load('purchases')  ?? [];
let items      = load('items')      ?? [];
let customers  = load('customers')  ?? [];
let suppliers  = load('suppliers')  ?? [];
let employees  = load('employees')  ?? [];
let invCounter = load('invCounter') ?? 1001;
let returns    = load('returns')    || [];
let transports = load('transports') || [];
let auditLog   = load('auditLog')   || [];
let lowThreshold = load('lowThreshold') ?? 100;

let appUsers = load('appUsers') || [{uname:'admin',fname:'المدير العام',role:'كاملة',pass:'1234'}];
let appConfig = load('appConfig') || {
  name:'شركة الإعمار للسيراميك والمرمر والبورسلاين',
  phone:'07800000000', addr:'بغداد - العراق',
