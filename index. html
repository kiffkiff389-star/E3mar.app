  const date=document.getElementById('ret_date').value||today;
  if(!cust||!item){alert('⚠️ أدخل اسم العميل والمادة');return;}
  if(qty<=0){alert('⚠️ أدخل الكمية المرتجعة');return;}
  // إعادة الكمية للمخزن تلقائياً
  const itemIdx=items.findIndex(it=>it.name.trim()===item.trim());
  if(itemIdx>=0){ items[itemIdx].qty+=qty; saveAll(); }
  const id='#R'+(returns.length+1);
  returns.unshift({id,inv,cust,item,qty,amount,reason,date:date.replace(/-/g,'/')});
  save('returns',returns);
  addAudit('delete','مرتجع جديد '+id+' من '+cust+' — تمت إعادة '+qty+' للمخزن');
  renderReturns(); renderItems(); closeModal('mReturn');
  ['ret_inv','ret_cust','ret_item','ret_qty','ret_amount'].forEach(id=>document.getElementById(id).value='');
