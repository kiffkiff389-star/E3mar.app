  sales:    {title:'💰 المبيعات',    sub:[{l:'📋 الفواتير',pg:'sales'},{l:'➕ فاتورة جديدة',fn:()=>openSaleModal()}]},
  purchases:{title:'🛒 المشتريات',   sub:[{l:'📋 المشتريات',pg:'purchases'},{l:'➕ شراء جديد',fn:()=>openModal('mPurchase')}]},
  inventory:{title:'📦 المخزن',      sub:[{l:'📋 المواد',pg:'inventory'},{l:'➕ إضافة مادة',fn:()=>openModal('mItem')}]},
  customers:{title:'👥 العملاء',     sub:[{l:'📋 العملاء',pg:'customers'},{l:'➕ عميل جديد',fn:()=>openModal('mCustomer')}]},
  suppliers:{title:'🏭 الموردون',    sub:[{l:'📋 الموردون',pg:'suppliers'},{l:'➕ مورد جديد',fn:()=>openModal('mSupplier')}]},
  employees:{title:'👨‍💼 الموظفون',   sub:[{l:'📋 الموظفون',pg:'employees'},{l:'➕ موظف جديد',fn:()=>openModal('mEmployee')}]},
  accounts: {title:'📊 الحسابات',    sub:[{l:'💵 الصندوق',pg:'accounts',fn:()=>renderAccounts()},{l:'📊 المبيعات',pg:'accounts',fn:()=>renderAccounts()},{l:'🛒 المشتريات',pg:'accounts',fn:()=>renderAccounts()},{l:'📈 الأرباح',pg:'accounts',fn:()=>renderAccounts()}]},
  reports:  {title:'📋 التقارير',    sub:[{l:'📊 التقارير',pg:'reports'}]},
  returns:  {title:'↩️ المرتجعات',   sub:[{l:'📋 المرتجعات',pg:'returns'}]},
  transport:{title:'🚚 النقل',       sub:[{l:'📋 النقل',pg:'transport'}]},
  users:    {title:'🔐 المستخدمون',  sub:[{l:'📋 المستخدمون',pg:'users'},{l:'📜 السجل',pg:'audit'}]},
  settings: {title:'⚙️ الإعدادات',   sub:[{l:'⚙️ الإعدادات',pg:'settings'}]},
};
const pgRenderMap={'accounts':()=>renderAccounts(),'reports':()=>renderReports(),'returns':()=>renderReturns(),'transport':()=>renderTransport(),'users':()=>renderUsers(),'settings':()=>loadSettings(),'audit':()=>renderAudit()};

// Permission rules per role
const rolePermissions={
  'كاملة':       ['sales','purchases','inventory','customers','suppliers','employees','accounts','reports','returns','transport','users','settings'],
  'مبيعات فقط': ['sales','customers','returns'],
  'مخزن فقط':   ['inventory','purchases','suppliers'],
  'حسابات + تقارير':['accounts','reports','sales','purchases'],
  'مشاهدة فقط': ['sales','purchases','inventory','customers','suppliers','employees','accounts','reports','returns','transport'],
};
const readOnlyModules=['مشاهدة فقط'];

function canAccess(section){
  if(!currentUser) return false;
  const allowed=rolePermissions[currentUser.role]||[];
  return allowed.includes(section);
}
function isReadOnly(){
  return readOnlyModules.includes(currentUser?.role);
}

function go(name){
  if(!currentUser){alert('⚠️ يجب تسجيل الدخول أولاً');return;}
  if(!canAccess(name)){
    alert('⛔ ليس لديك صلاحية للوصول إلى هذا القسم\nصلاحياتك: '+currentUser.role);
    return;
  }
  const m=modules[name];
  document.getElementById('home').style.display='none';
  document.getElementById('shell').classList.add('on');
  document.getElementById('modTitle').textContent=m.title;
  const sm=document.getElementById('subMenu'); sm.innerHTML='';
  m.sub.forEach((s,i)=>{
    const b=document.createElement('button'); b.className='sub-btn'+(i===0?' active':''); b.textContent=s.l;
    b.onclick=()=>{
      sm.querySelectorAll('.sub-btn').forEach(x=>x.classList.remove('active')); b.classList.add('active');
      if(s.pg){showPg(s.pg);setTimeout(()=>{if(s.fn)s.fn();else if(pgRenderMap[s.pg])pgRenderMap[s.pg]();},30);}
      else if(s.fn) s.fn();
    };
    sm.appendChild(b);
  });
  if(m.sub[0].pg){
    showPg(m.sub[0].pg);
    setTimeout(()=>{if(m.sub[0].fn)m.sub[0].fn();else if(pgRenderMap[m.sub[0].pg])pgRenderMap[m.sub[0].pg]();},30);
  }
}
function showPg(name){ document.querySelectorAll('.page').forEach(p=>p.classList.remove('on')); const pg=document.getElementById('pg-'+name); if(pg) pg.classList.add('on'); }
function goHome(){ document.getElementById('home').style.display='flex'; document.getElementById('shell').classList.remove('on'); document.querySelectorAll('.page').forEach(p=>p.classList.remove('on')); }
function openModal(id){ document.getElementById(id).classList.add('on'); }
function closeModal(id){ document.getElementById(id).classList.remove('on'); }
document.querySelectorAll('.overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m) m.classList.remove('on');}));

// ══════════════════════════════════════════
// ── RENDER ALL & INIT ──
// ══════════════════════════════════════════
function renderAll(){ renderSales();renderPurch();renderItems();renderCust();renderSupp();renderEmp(); }
// ── App Startup with Firebase ──
async function startApp(){
  const loadingEl = document.getElementById('fb-loading');
  
  // Init Firebase
  await initFirebase();
  
  if(firebaseReady){
    // Load from Firebase (overrides localStorage)
    await loadFromFirebase();
    // Start real-time sync
    startRealtimeSync();
  }
  
  // Reload data after Firebase load
  sales      = load('sales')      ?? [];
  purchases  = load('purchases')  ?? [];
  items      = load('items')      ?? [];
  customers  = load('customers')  ?? [];
  suppliers  = load('suppliers')  ?? [];
  employees  = load('employees')  ?? [];
  invCounter = load('invCounter') ?? 1001;
  returns    = load('returns')    || [];
  transports = load('transports') || [];
  auditLog   = load('auditLog')   || [];
  lowThreshold = load('lowThreshold') ?? 100;
  appUsers   = load('appUsers')   || [{uname:'admin',fname:'المدير العام',role:'كاملة',pass:'1234'}];
  appConfig  = load('appConfig')  || {name:'شركة الإعمار للسيراميك والمرمر والبورسلاين',phone:'07800000000',addr:'بغداد - العراق',email:'info@aliemaar.com',currency:'دينار',admin:'المدير العام'};
  
  // Hide loading
  if(loadingEl) loadingEl.style.display='none';
  
  applyCompanyConfig();
  renderAll();
  
  // Check old demo data
  if(sales.length&&sales.some(x=>x.id==='#1042'||x.id==='#1041'||x.id==='#1040'||x.id==='#1039')){
    const n=document.getElementById('oldDataNotice'); if(n) n.style.display='flex';
  }
  
  const syncBadge = document.getElementById('syncBadge');
  if(syncBadge) syncBadge.style.display = firebaseReady ? 'flex' : 'none';
}

startApp();

// Keyboard shortcut: Enter on login
document.getElementById('li_pass').addEventListener('keydown',e=>{if(e.key==='Enter') doLogin();});
</script>

