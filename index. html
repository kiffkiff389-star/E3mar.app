<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>شركة الإعمار — النظام المتكامل v2</title>
<style>
/* Offline-safe Arabic font stack — no internet needed */

/* ===== DEVELOPER BRAND ===== */
.dev-footer{background:linear-gradient(135deg,#0f3460,#1a1a2e);padding:14px 18px;display:flex;align-items:center;justify-content:space-between;border-top:2px solid rgba(200,16,46,0.4);}
.dev-footer .dev-info{display:flex;align-items:center;gap:10px;}
.dev-footer .dev-logo{width:36px;height:36px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.dev-footer .dev-name{font-size:12px;font-weight:800;color:#fff;}
.dev-footer .dev-sub{font-size:10px;color:rgba(255,255,255,0.45);}
.dev-footer .dev-wa{background:#25D366;color:#fff;border:none;border-radius:8px;padding:7px 13px;font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px;text-decoration:none;}
.dev-footer .dev-wa:hover{background:#1ebe5d;}
.dev-about-btn{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);border-radius:8px;padding:6px 11px;font-size:11px;font-weight:700;cursor:pointer;}
.dev-about-btn:hover{background:rgba(255,255,255,0.15);color:#fff;}

/* About modal */
.about-box{background:#fff;border-radius:20px;padding:28px 22px;width:92%;max-width:380px;text-align:center;}
.about-box .ab-logo{width:72px;height:72px;background:linear-gradient(135deg,#c8102e,#9e0c24);border-radius:18px;display:inline-flex;align-items:center;justify-content:center;font-size:34px;margin-bottom:14px;box-shadow:0 8px 24px rgba(200,16,46,0.35);}
.about-box h2{font-size:18px;font-weight:900;color:#1a1a2e;margin-bottom:4px;}
.about-box .ab-ver{font-size:11px;color:#6b7280;margin-bottom:16px;}
.about-box .ab-features{background:#f0f2f5;border-radius:12px;padding:12px 14px;text-align:right;margin-bottom:16px;}
.about-box .ab-feat-row{display:flex;align-items:center;gap:8px;padding:5px 0;font-size:12px;color:#374151;border-bottom:1px solid #e5e7eb;}
.about-box .ab-feat-row:last-child{border-bottom:none;}
.about-box .ab-dev{background:linear-gradient(135deg,#0f3460,#1a1a2e);border-radius:12px;padding:14px;margin-bottom:14px;}
.about-box .ab-dev-name{font-size:14px;font-weight:900;color:#fff;margin-bottom:2px;}
.about-box .ab-dev-sub{font-size:11px;color:rgba(255,255,255,0.5);}
.about-box .ab-wa{background:#25D366;color:#fff;border:none;border-radius:10px;padding:11px;width:100%;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;}
.about-box .ab-wa:hover{background:#1ebe5d;}

</style>
<style>
:root {
  --primary:#c8102e; --primary-dark:#9e0c24; --accent:#e8c56d;
  --bg:#f0f2f5; --dark:#1a1a2e; --text:#1a1a2e; --light:#6b7280;
  --border:#e5e7eb; --success:#10b981; --warning:#f59e0b; --danger:#ef4444;
  --info:#3b82f6;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI','Tahoma','Arial',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* ===== LOGIN ===== */
#loginScreen{min-height:100vh;background:linear-gradient(135deg,#1a1a2e,#0f3460);display:flex;align-items:center;justify-content:center;padding:20px;}
.login-box{background:#fff;border-radius:24px;padding:36px 28px;width:100%;max-width:380px;box-shadow:0 24px 64px rgba(0,0,0,0.3);}
.login-logo{text-align:center;margin-bottom:28px;}
.login-logo .logo-icon{width:72px;height:72px;background:var(--primary);border-radius:18px;display:inline-flex;align-items:center;justify-content:center;font-size:36px;margin-bottom:12px;box-shadow:0 8px 24px rgba(200,16,46,0.35);}
.login-logo h1{font-size:20px;font-weight:900;color:var(--dark);}
.login-logo p{font-size:12px;color:var(--light);}
.login-field{margin-bottom:16px;}
.login-field label{display:block;font-size:12px;font-weight:700;color:var(--light);margin-bottom:6px;}
.login-field input{width:100%;border:1.5px solid var(--border);border-radius:10px;padding:11px 14px;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:14px;outline:none;transition:border .2s;}
.login-field input:focus{border-color:var(--primary);}
.login-btn{width:100%;background:var(--primary);color:#fff;border:none;border-radius:10px;padding:13px;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:15px;font-weight:700;cursor:pointer;transition:background .2s;margin-top:8px;}
.login-btn:hover{background:var(--primary-dark);}
.login-hint{text-align:center;margin-top:16px;font-size:11px;color:var(--light);}
.login-error{background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:10px 14px;font-size:12px;color:#991b1b;margin-bottom:14px;display:none;}

/* ===== HOME ===== */
#home{min-height:100vh;background:linear-gradient(135deg,#1a1a2e,#0f3460);display:flex;flex-direction:column;}
.home-header{padding:20px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.08);}
.home-logo{display:flex;align-items:center;gap:12px;}
.home-logo-icon{width:52px;height:52px;background:var(--primary);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;box-shadow:0 4px 16px rgba(200,16,46,0.4);}
.home-logo h1{font-size:16px;font-weight:900;color:#fff;line-height:1.3;}
.home-logo span{font-size:11px;color:rgba(255,255,255,0.5);}
.home-meta{text-align:left;}
.home-meta .hdate{font-size:11px;color:rgba(255,255,255,0.5);}
.home-meta .huser{font-size:13px;font-weight:700;color:var(--accent);}
.logout-btn{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;border-radius:8px;padding:5px 11px;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:12px;font-weight:700;cursor:pointer;margin-top:4px;transition:all .2s;}
.logout-btn:hover{background:var(--primary);}
.home-welcome{text-align:center;padding:18px 16px 8px;}
.home-welcome h2{font-size:20px;font-weight:900;color:#fff;margin-bottom:4px;}
.home-welcome p{font-size:12px;color:rgba(255,255,255,0.5);}
.icon-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:12px 14px 24px;flex:1;align-content:start;}
.icon-card{background:rgba(255,255,255,0.07);border:1.5px solid rgba(255,255,255,0.1);border-radius:16px;padding:18px 10px 14px;text-align:center;cursor:pointer;transition:all .22s;position:relative;}
.icon-card:active{transform:scale(.96);}
.icon-card:hover{border-color:var(--primary);background:rgba(200,16,46,0.12);}
.icon-card .big{font-size:36px;display:block;margin-bottom:8px;}
.icon-card h3{font-size:13px;font-weight:800;color:#fff;margin-bottom:2px;}
.icon-card p{font-size:10px;color:rgba(255,255,255,0.45);}
.icon-card .cnt{position:absolute;top:8px;left:8px;background:var(--primary);color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;}

/* ===== SHELL ===== */
#shell{display:none;flex-direction:column;min-height:100vh;}
#shell.on{display:flex;}
.topbar{background:#fff;padding:10px 14px;display:flex;align-items:center;gap:10px;border-bottom:2px solid var(--border);position:sticky;top:0;z-index:50;box-shadow:0 2px 8px rgba(0,0,0,0.06);}
.back-btn{background:var(--bg);border:1.5px solid var(--border);border-radius:9px;padding:7px 12px;cursor:pointer;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:13px;font-weight:700;white-space:nowrap;color:var(--text);transition:all .2s;}
.back-btn:hover{background:var(--primary);color:#fff;border-color:var(--primary);}
.topbar-title{font-size:16px;font-weight:900;color:var(--primary);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.user-badge{background:var(--primary);color:#fff;padding:5px 10px;border-radius:16px;font-size:11px;font-weight:700;white-space:nowrap;}
.sub-menu{background:var(--dark);padding:10px 12px;display:flex;gap:8px;overflow-x:auto;border-bottom:2px solid rgba(255,255,255,0.05);}
.sub-menu::-webkit-scrollbar{height:3px;}
.sub-menu::-webkit-scrollbar-thumb{background:var(--primary);border-radius:4px;}
.sub-btn{background:rgba(255,255,255,0.07);border:1.5px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.85);border-radius:9px;padding:8px 14px;cursor:pointer;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:12px;font-weight:700;white-space:nowrap;transition:all .2s;flex-shrink:0;}
.sub-btn.active,.sub-btn:hover{background:var(--primary);color:#fff;border-color:var(--primary);}
.content{padding:16px;flex:1;overflow-x:hidden;}
.page{display:none;}
.page.on{display:block;}

/* section header */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px;}
.sec-title{font-size:18px;font-weight:900;}
.sec-title span{color:var(--primary);}

/* stats */
.stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.stat{background:#fff;border-radius:10px;padding:12px;display:flex;align-items:center;gap:10px;box-shadow:0 2px 8px rgba(0,0,0,0.05);border-right:4px solid transparent;}
.stat.red{border-right-color:var(--primary);}
.stat.gold{border-right-color:var(--accent);}
.stat.green{border-right-color:var(--success);}
.stat.blue{border-right-color:var(--info);}
.stat .sicon{font-size:22px;width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.stat .sicon.red{background:#fef2f2;}
.stat .sicon.gold{background:#fffbeb;}
.stat .sicon.green{background:#f0fdf4;}
.stat .sicon.blue{background:#eff6ff;}
.stat h3{font-size:17px;font-weight:900;}
.stat p{font-size:10px;color:var(--light);}

/* card */
.card{background:#fff;border-radius:12px;padding:14px;margin-bottom:14px;box-shadow:0 2px 8px rgba(0,0,0,0.05);overflow:hidden;}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.card-title{font-size:14px;font-weight:800;display:flex;align-items:center;gap:6px;}
.card-title::before{content:'';width:3px;height:16px;background:var(--primary);border-radius:3px;display:inline-block;}

/* TABLE */
.tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
.tbl-wrap table{width:100%;border-collapse:collapse;min-width:500px;}
.tbl-wrap th{background:var(--bg);padding:9px 10px;text-align:right;font-size:11px;font-weight:700;color:var(--light);border-bottom:2px solid var(--border);white-space:nowrap;}
.tbl-wrap td{padding:9px 10px;font-size:12px;border-bottom:1px solid var(--border);vertical-align:middle;}
.tbl-wrap tr:hover td{background:#fafafa;}

/* mobile row-card */
.row-cards{display:none;}
.row-card{background:#fff;border-radius:10px;padding:12px;margin-bottom:10px;box-shadow:0 1px 6px rgba(0,0,0,0.07);border-right:3px solid var(--primary);}
.row-card .rc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;}
.row-card .rc-name{font-size:14px;font-weight:800;}
.row-card .rc-num{font-size:11px;color:var(--light);}
.row-card .rc-body{display:grid;grid-template-columns:1fr 1fr;gap:4px 10px;}
.row-card .rc-field{font-size:11px;color:var(--light);}
.row-card .rc-field span{color:var(--text);font-weight:700;}
.row-card .rc-actions{display:flex;gap:6px;margin-top:10px;flex-wrap:wrap;}

@media(max-width:600px){
  .tbl-wrap{display:none;}
  .row-cards{display:block;}
}

/* badges */
.badge{padding:3px 9px;border-radius:16px;font-size:10px;font-weight:700;}
.badge-success{background:#dcfce7;color:#166534;}
.badge-warning{background:#fef9c3;color:#854d0e;}
.badge-danger{background:#fee2e2;color:#991b1b;}
.badge-info{background:#dbeafe;color:#1e40af;}

/* buttons */
.btn{padding:8px 16px;border-radius:8px;border:none;cursor:pointer;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:13px;font-weight:700;transition:all .2s;display:inline-flex;align-items:center;gap:5px;}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{background:var(--primary-dark);}
.btn-danger{background:#fee2e2;color:var(--danger);}
.btn-danger:hover{background:var(--danger);color:#fff;}
.btn-secondary{background:var(--bg);color:var(--text);border:1px solid var(--border);}
.btn-sm{padding:5px 10px;font-size:11px;}
.btn-edit{background:#eff6ff;color:#2563eb;}
.btn-edit:hover{background:#2563eb;color:#fff;}
.btn-success{background:#dcfce7;color:#166534;}
.btn-success:hover{background:var(--success);color:#fff;}

/* search */
.search-bar{display:flex;gap:8px;margin-bottom:12px;}
.search-bar input{flex:1;border:1.5px solid var(--border);border-radius:8px;padding:9px 12px;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:13px;outline:none;}
.search-bar input:focus{border-color:var(--primary);}

/* forms */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group label{font-size:11px;font-weight:700;color:var(--light);}
.form-group input,.form-group select,.form-group textarea{border:1.5px solid var(--border);border-radius:8px;padding:9px 11px;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:13px;outline:none;transition:border .2s;width:100%;}
.form-group input:focus,.form-group select:focus{border-color:var(--primary);}
.span2{grid-column:span 2;}

/* modal */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:999;align-items:flex-end;justify-content:center;}
.overlay.on{display:flex;}
.modal{background:#fff;border-radius:20px 20px 0 0;padding:22px 18px 28px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;}
.modal-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.modal-title{font-size:17px;font-weight:900;color:var(--primary);}
.modal-close{background:none;border:none;font-size:22px;cursor:pointer;color:var(--light);}
.modal-btns{display:flex;gap:8px;justify-content:flex-end;margin-top:16px;}

/* receipt */
.rcpt-hdr{text-align:center;border-bottom:2px dashed var(--border);padding-bottom:12px;margin-bottom:12px;}
.rcpt-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #f3f4f6;font-size:13px;}
.rcpt-total{display:flex;justify-content:space-between;padding:10px 0;font-size:15px;font-weight:900;color:var(--primary);border-top:2px solid var(--primary);margin-top:8px;}
.rcpt-items-table{width:100%;border-collapse:collapse;margin:10px 0;font-size:12px;}
.rcpt-items-table th{background:#f8f9fa;padding:7px 8px;text-align:right;border:1px solid var(--border);}
.rcpt-items-table td{padding:7px 8px;border:1px solid var(--border);text-align:right;}

/* empty state */
.empty{text-align:center;padding:40px 20px;color:var(--light);}
.empty .empty-icon{font-size:48px;margin-bottom:10px;}

/* confirm delete */
.confirm-box{background:#fff;border-radius:16px;padding:24px;width:90%;max-width:360px;text-align:center;}
.confirm-box h3{font-size:17px;font-weight:900;margin-bottom:8px;}
.confirm-box p{font-size:13px;color:var(--light);margin-bottom:20px;}
.confirm-btns{display:flex;gap:10px;justify-content:center;}

/* reports */
.rpt-tab{background:var(--bg);border:1.5px solid var(--border);border-radius:9px;padding:7px 13px;cursor:pointer;font-family:'Segoe UI','Tahoma','Arial',sans-serif;font-size:12px;font-weight:700;transition:all .2s;}
.rpt-tab.active,.rpt-tab:hover{background:var(--primary);color:#fff;border-color:var(--primary);}

/* chart */
.chart-container{position:relative;width:100%;height:200px;margin-top:10px;}
.chart-bar-wrap{display:flex;align-items:flex-end;gap:6px;height:160px;padding:0 4px;border-bottom:2px solid var(--border);}
.chart-bar{flex:1;border-radius:6px 6px 0 0;min-width:20px;transition:all .4s;cursor:pointer;position:relative;}
.chart-bar:hover{opacity:.8;}
.chart-bar .bar-tip{position:absolute;top:-22px;left:50%;transform:translateX(-50%);font-size:9px;font-weight:700;white-space:nowrap;color:var(--text);}
.chart-labels{display:flex;gap:6px;padding:4px 4px 0;}
.chart-label{flex:1;text-align:center;font-size:9px;color:var(--light);font-weight:700;}

/* profit indicator */
.profit-bar{height:12px;border-radius:6px;background:linear-gradient(90deg,var(--danger),var(--warning),var(--success));position:relative;overflow:hidden;margin:8px 0;}
.profit-needle{position:absolute;top:-3px;width:4px;height:18px;background:#1a1a2e;border-radius:2px;transition:left .5s;}

/* audit log */
.audit-item{padding:10px 12px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:10px;font-size:12px;}
.audit-item:last-child{border-bottom:none;}
.audit-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.audit-dot.sale{background:var(--success);}
.audit-dot.purchase{background:var(--info);}
.audit-dot.delete{background:var(--danger);}
.audit-dot.payment{background:var(--accent);}
.audit-dot.login{background:#8b5cf6;}
.audit-time{color:var(--light);font-size:10px;white-space:nowrap;}

/* due date warning */
.due-soon{background:#fffbeb;border-right:3px solid var(--warning);}
.due-overdue{background:#fff8f8;border-right:3px solid var(--danger);}

/* customer invoice drawer */
.cust-invoices{background:var(--bg);border-radius:10px;padding:10px;margin-top:10px;}
.cust-inv-row{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;background:#fff;border-radius:8px;margin-bottom:6px;font-size:12px;box-shadow:0 1px 4px rgba(0,0,0,0.05);}

/* export buttons */
.export-btns{display:flex;gap:8px;flex-wrap:wrap;}

/* multi-item invoice */
.invoice-items{border:1.5px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:12px;}
.invoice-item-row{display:grid;grid-template-columns:2fr 1fr 1fr auto;gap:8px;padding:10px;border-bottom:1px solid var(--border);align-items:center;}
.invoice-item-row:last-child{border-bottom:none;}
.invoice-item-row.header{background:var(--bg);font-size:11px;font-weight:700;color:var(--light);}
.invoice-total-row{display:flex;justify-content:space-between;align-items:center;padding:10px 12px;background:#f0fdf4;font-weight:800;}

/* margin badge */
.margin-badge{padding:2px 7px;border-radius:10px;font-size:10px;font-weight:700;}
.margin-high{background:#dcfce7;color:#166534;}
.margin-mid{background:#fef9c3;color:#854d0e;}
.margin-low{background:#fee2e2;color:#991b1b;}

/* settings */
.danger-zone{background:#fff8f8;border:1.5px solid #fecaca;border-radius:12px;padding:14px;margin-top:14px;}

@media print {
  #loginScreen,#home,#shell .topbar,#shell .sub-menu,#shell .content > :not(.print-area){display:none!important;}
  .print-area{display:block!important;}
}
</style>
<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>

<!-- Loading Screen Style -->
<style>
#fb-loading{position:fixed;inset:0;background:linear-gradient(135deg,#1a1a2e,#0f3460);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
#fb-loading .fb-spin{width:60px;height:60px;border:4px solid rgba(255,255,255,0.15);border-top-color:#c8102e;border-radius:50%;animation:fbspin 0.8s linear infinite;}
#fb-loading .fb-logo{font-size:48px;margin-bottom:8px;}
#fb-loading h2{color:#fff;font-size:18px;font-weight:900;}
#fb-loading p{color:rgba(255,255,255,0.6);font-size:13px;}
@keyframes fbspin{to{transform:rotate(360deg);}}
</style>
</head>
<body>

<!-- ===== CHANGE CREDENTIALS MODAL ===== -->
<div class="overlay" id="mChangeCredentials">
  <div class="modal" style="border-radius:20px 20px 0 0;">
    <div class="modal-hdr">
      <div class="modal-title">🔑 تغيير بيانات الدخول</div>
      <button class="modal-close" onclick="closeModal('mChangeCredentials')">✕</button>
    </div>
    <div id="credChangeError" style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:10px 14px;font-size:12px;color:#991b1b;margin-bottom:14px;display:none;"></div>
    <div id="credChangeSuccess" style="background:#dcfce7;border:1px solid #86efac;border-radius:8px;padding:10px 14px;font-size:12px;color:#166534;margin-bottom:14px;display:none;"></div>
    <div class="form-grid">
      <div class="form-group span2">
        <label>اسم المستخدم الجديد</label>
