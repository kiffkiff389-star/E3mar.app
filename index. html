function renderAccounts(){
  if(!document.getElementById('acc-income')){setTimeout(renderAccounts,50);return;}
  const totalIncome=sales.reduce((s,x)=>s+x.total,0);
  const totalExpense=purchases.reduce((s,x)=>s+x.total,0);
  const totalCash=sales.reduce((s,x)=>s+(x.paid||0),0);
  const profit=totalIncome-totalExpense;
  document.getElementById('acc-income').textContent=N(totalIncome);
  document.getElementById('acc-expense').textContent=N(totalExpense);
  document.getElementById('acc-profit').textContent=N(profit);
  document.getElementById('acc-cash').textContent=N(totalCash);

  // Sales chart — last 6 months
  renderSalesChart();

  const stbl=document.getElementById('accSalesTbl');
  if(stbl) stbl.innerHTML=sales.length?sales.map(s=>{
    const rem=s.total-(s.paid||0);
    const summary=saleItemsSummary(s.lines||[]);
    return `<tr><td style="font-weight:800">${s.id}</td><td>${s.date}</td><td>${s.cust}</td>
      <td>${summary}</td><td style="font-weight:800">${N(s.total)}</td>
      <td style="color:var(--success);font-weight:800">${N(s.paid||0)}</td>
      <td style="color:${rem>0?'var(--danger)':'var(--success)'};font-weight:800">${N(rem)}</td></tr>`;}).join('')
  :'<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--light)">لا توجد مبيعات</td></tr>';

  const ptbl=document.getElementById('accPurchTbl');
  if(ptbl) ptbl.innerHTML=purchases.length?purchases.map(p=>{
    const rem=p.total-(p.paid||0);
    return `<tr><td style="font-weight:800">${p.id}</td><td>${p.date}</td><td>${p.supp}</td><td>${p.item}</td><td>${p.qty}</td>
      <td style="font-weight:800">${N(p.total)}</td><td style="color:var(--success);font-weight:800">${N(p.paid||0)}</td>
      <td style="color:${rem>0?'var(--danger)':'var(--success)'};font-weight:800">${N(rem)}</td></tr>`;}).join('')
  :'<tr><td colspan="8" style="text-align:center;padding:20px;color:var(--light)">لا توجد مشتريات</td></tr>';

  const profTbl=document.getElementById('accProfitTbl');
  if(profTbl){
    const rows=[];
    [...sales].reverse().forEach(s=>rows.push({date:s.date,label:'بيع — '+s.cust,in_:s.total,out_:0}));
    [...purchases].reverse().forEach(p=>rows.push({date:p.date,label:'شراء — '+p.supp+' ('+p.item+')',in_:0,out_:p.total}));
    rows.sort((a,b)=>a.date>b.date?-1:1);
    profTbl.innerHTML=rows.length?rows.map(r=>`<tr>
      <td>${r.date}</td><td>${r.label}</td>
      <td style="color:var(--success);font-weight:800">${r.in_>0?N(r.in_):'-'}</td>
      <td style="color:var(--danger);font-weight:800">${r.out_>0?N(r.out_):'-'}</td></tr>`).join('')
    :'<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--light)">لا توجد بيانات</td></tr>';
    const pt=document.getElementById('acc-profit-total');
    if(pt){pt.textContent=N(profit)+' دينار';pt.style.color=profit>=0?'var(--success)':'var(--danger)';}
  }

  const ctbl=document.getElementById('accTbl');
  if(ctbl){
    let cashBalance=0;
    const cashRows=[];
    [...sales].reverse().forEach(s=>{if(s.paid>0){cashBalance+=s.paid;cashRows.push({date:s.date,type:'وارد',party:s.cust,label:'فاتورة بيع '+s.id,in_:s.paid,out_:0,bal:cashBalance});}});
    [...purchases].reverse().forEach(p=>{if(p.paid>0){cashBalance-=p.paid;cashRows.push({date:p.date,type:'صادر',party:p.supp,label:'دفعة مورد '+p.id,in_:0,out_:p.paid,bal:cashBalance});}});
    cashRows.sort((a,b)=>a.date>b.date?-1:1);
    ctbl.innerHTML=cashRows.length?cashRows.map(r=>`<tr>
      <td>${r.date}</td>
      <td><span class="badge ${r.type==='وارد'?'badge-success':'badge-danger'}">${r.type}</span></td>
      <td>${r.party}</td><td>${r.label}</td>
      <td style="color:var(--success);font-weight:800">${r.in_>0?N(r.in_):'-'}</td>
      <td style="color:var(--danger);font-weight:800">${r.out_>0?N(r.out_):'-'}</td>
      <td style="font-weight:800">${N(r.bal)}</td></tr>`).join('')
    :'<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--light)">لا توجد حركات</td></tr>';
    const ct=document.getElementById('acc-cash-total');
    if(ct) ct.textContent=N(totalCash)+' دينار';
  }
  showAccPanel('cash');
}

