function filterSales(){
  const q=document.getElementById('searchSales').value.trim().toLowerCase();
  if(!q){renderSales();return;}
  const filtered=sales.filter(s=>s.cust.toLowerCase().includes(q)||s.id.toLowerCase().includes(q)||s.date.includes(q)||(s.lines&&s.lines.some(l=>l.name.toLowerCase().includes(q))));
  const tbl=document.getElementById('salesTbl'); const cards=document.getElementById('salesCards');
  tbl.innerHTML=''; cards.innerHTML='';
  if(!filtered.length){tbl.innerHTML='<tr><td colspan="10" style="text-align:center;padding:20px;color:var(--light)">لا توجد نتائج</td></tr>';return;}
  filtered.forEach((s)=>{
    const rem=s.total-s.paid; const i=sales.indexOf(s);
    const summary=saleItemsSummary(s.lines||[]);
    tbl.innerHTML+=`<tr><td>${s.id}</td><td>${s.cust}</td><td>${summary}</td>
      <td>${N(s.total)}</td><td>${N(s.paid)}</td><td style="color:${rem>0?'var(--danger)':'var(--success)'}">${N(rem)}</td>
      <td>${s.dueDate?dueBadge(s.dueDate):'-'}</td><td>${s.date}</td><td>${statusBadge(s.paid,s.total)}</td>
      <td><button class="btn btn-secondary btn-sm" onclick="printSale(${i})">🖨️</button>
      <button class="btn btn-danger btn-sm" onclick="confirmDel('sales',${i})">🗑️</button></td></tr>`;
  });
}

function filterItems(){
  const q=document.getElementById('searchItems').value.trim().toLowerCase();
  if(!q){renderItems();return;}
  const tbl=document.getElementById('itemTbl'); tbl.innerHTML='';
  const low=lowThreshold;
  items.filter(it=>it.name.toLowerCase().includes(q)||it.cat.toLowerCase().includes(q)).forEach(it=>{
    const i=items.indexOf(it);
    const invVal=it.qty*it.buy;
    tbl.innerHTML+=`<tr><td>${it.code}</td><td style="font-weight:700">${it.name}</td><td>${it.cat}</td><td>${it.unit}</td>
      <td style="font-weight:800;color:${it.qty<=0?'var(--danger)':it.qty<=low?'var(--warning)':'var(--success)'}">${it.qty}</td>
      <td>${N(it.buy)}</td><td>${N(it.sell)}</td><td>${marginBadge(it.buy,it.sell)}</td>
      <td>${N(invVal)}</td><td>${itemBadge(it.qty)}</td>
      <td><button class="btn btn-edit btn-sm" onclick="openAddQtyModal(${i})">➕</button>
      <button class="btn btn-danger btn-sm" onclick="confirmDel('items',${i})">🗑️</button></td></tr>`;
  });
}

