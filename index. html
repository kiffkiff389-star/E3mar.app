// ── SAVE SALE ──
// ══════════════════════════════════════════
function saveSale(){
  const cust=document.getElementById("s_cust").value||"عميل جديد";
  const dueDate=document.getElementById("s_due").value||"";
  const lines=[];
  let grand=0;
  let hasError=false;

  document.querySelectorAll("#saleItemRows .invoice-item-row").forEach(row=>{
    const rowId=row.id;
    const nameEl=document.getElementById(rowId+"_name");
    const qtyEl=document.getElementById(rowId+"_qty");
    const priceEl=document.getElementById(rowId+"_price");
    const itemName=nameEl?nameEl.value.trim():"";
    const qty=parseFloat(qtyEl?.value)||0;
    const price=parseFloat(priceEl?.value)||0;
    if(!itemName||qty<=0){ hasError=true; return; }
    const sub=qty*price;
    grand+=sub;
    lines.push({name:itemName,qty,price,sub});
  });

  if(!lines.length||hasError){alert("⚠️ أدخل اسم المادة والكمية لكل بند");return;}

  for(const line of lines){
    const idx=items.findIndex(it=>it.name===line.name);
    if(idx>=0){
      if(items[idx].qty<=0){
        alert("⚠️ المادة \""+line.name+"\" نافدة من المخزن (الكمية: 0)");
        return;
      }
      if(items[idx].qty<line.qty){
        alert("⚠️ الكمية المطلوبة ("+line.qty+") لـ \""+line.name+"\" أكبر من المتوفر ("+items[idx].qty+")");
        return;
      }
    }
  }
  for(const line of lines){
    const idx=items.findIndex(it=>it.name===line.name);
    if(idx>=0) items[idx].qty-=line.qty;
  }

  const paid=parseFloat(document.getElementById("s_paid").value)||0;
  const saleId="#"+invCounter++;
  sales.unshift({id:saleId,cust,lines,total:grand,paid,dueDate,date:today.replace(/-/g,"/")});
  saveAll();
  addAudit("sale","فاتورة بيع جديدة "+saleId+" — "+cust+" — "+N(grand)+" دينار");
  renderSales();renderItems();
  closeModal("mSale");
  alert("✅ تم حفظ الفاتورة بنجاح!");
  updateHomeCounters();
}

