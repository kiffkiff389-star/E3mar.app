  if(!item||item==='مادة'){alert('⚠️ أدخل اسم المادة');return;}
  if(qty<=0){alert('⚠️ أدخل الكمية');return;}
  const pid='#P'+(200+purchases.length+1);
  purchases.unshift({id:pid,supp,item,qty:qty+' '+unit,total,paid:total,date:today.replace(/-/g,'/'),status:'مستلمة'});
  const existIdx=items.findIndex(it=>it.name.trim()===item.trim());
  if(existIdx>=0){ items[existIdx].qty+=qty; if(price>0) items[existIdx].buy=price; if(sell>0) items[existIdx].sell=sell; }
  else { const code=(cat[0]||'X')+(String(items.length+1).padStart(3,'0')); items.push({code,name:item,cat,unit,qty,buy:price,sell}); }
  saveAll();
  addAudit('purchase',`فاتورة شراء ${pid} — ${supp} — ${item} — ${N(total)} دينار`);
  renderPurch(); renderItems(); closeModal('mPurchase');
  ['p_supp','p_item','p_qty','p_price','p_sell','p_total'].forEach(id=>document.getElementById(id).value='');
  alert('✅ تم حفظ فاتورة الشراء وتحديث المخزن!');
}

