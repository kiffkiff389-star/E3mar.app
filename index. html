<script>
// ══════════════════════════════════════════
// ── CORE DATA & PERSISTENCE ──
// ══════════════════════════════════════════
const now = new Date();
const today = now.toISOString().split('T')[0];
document.getElementById('homeDate').textContent = now.toLocaleDateString('ar-IQ',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
document.querySelectorAll('input[type="date"]').forEach(el=>el.value=today);


// ══════════════════════════════════════════
// ── FIREBASE SECURITY NOTE ──
// ══════════════════════════════════════════
// قواعد الأمان الموصى بها في Firebase Console:
// {
