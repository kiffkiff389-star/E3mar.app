};

// ══════════════════════════════════════════
// ── AUDIT LOG ──
// ══════════════════════════════════════════
let currentUser = null;

function addAudit(type, msg){
  const entry = {
    type, msg,
    user: currentUser ? currentUser.fname : '?',
    time: new Date().toLocaleString('ar-IQ')
  };
  auditLog.unshift(entry);
  if(auditLog.length > 300) auditLog = auditLog.slice(0,300);
  save('auditLog', auditLog);
}

function renderAudit(){
  const el = document.getElementById('auditList');
  if(!el) return;
  if(!auditLog.length){ el.innerHTML='<div class="empty"><div class="empty-icon">📜</div><p>لا توجد سجلات</p></div>'; return; }
  el.innerHTML = auditLog.map(e=>`
    <div class="audit-item">
      <div class="audit-dot ${e.type}"></div>
      <div style="flex:1;">
        <div style="font-weight:700;">${e.msg}</div>
        <div style="color:var(--light);font-size:10px;">👤 ${e.user} &nbsp;|&nbsp; 🕐 ${e.time}</div>
      </div>
    </div>`).join('');
