function exportCSV(){
  const {from,to}=getDateFilter();
  const filtSales=sales.filter(s=>inDateRange(s.date,from,to));
  const rows=[['رقم الفاتورة','التاريخ','العميل','البنود','الإجمالي','المدفوع','المتبقي','الحالة']];
  filtSales.forEach(s=>{
