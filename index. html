function submitEditPurch(){
  if(editPurchIdx===null){savePurch();return;}
  const p=purchases[editPurchIdx];
  const supp=document.getElementById('p_supp').value||p.supp;
  const item=document.getElementById('p_item').value||p.item;
  const cat=document.getElementById('p_cat').value;
  const unit=document.getElementById('p_unit').value;
  const qty=parseFloat(document.getElementById('p_qty').value)||0;
  const price=parseFloat(document.getElementById('p_price').value)||0;
  const sell=parseFloat(document.getElementById('p_sell').value)||0;
  const total=qty*price;
  if(qty<=0){alert('⚠️ أدخل الكمية');return;}
  // Restore old stock
  const oldQty=parseFloat(p.qty)||0;
  const existOld=items.findIndex(it=>it.name===p.item);
  if(existOld>=0) items[existOld].qty-=oldQty;
  // Apply new stock
  const existNew=items.findIndex(it=>it.name===item);
  if(existNew>=0){items[existNew].qty+=qty;if(price>0)items[existNew].buy=price;if(sell>0)items[existNew].sell=sell;}
  else{const code=(cat[0]||'X')+(String(items.length+1).padStart(3,'0'));items.push({code,name:item,cat,unit,qty,buy:price,sell});}
  purchases[editPurchIdx]={...p,supp,item,qty:qty+' '+unit,total,date:document.getElementById('p_date').value.replace(/-/g,'/')};
  saveAll(); addAudit('purchase','تعديل فاتورة شراء '+p.id); renderPurch(); renderItems();
  closeModal('mPurchase'); editPurchIdx=null;
  document.querySelector('#mPurchase .modal-title').textContent='🛒 فاتورة شراء جديدة';
  document.querySelector('#mPurchase .modal-btns .btn-primary').textContent='💾 حفظ وإضافة للمخزن';
  document.querySelector('#mPurchase .modal-btns .btn-primary').onclick=savePurch;
  alert('✅ تم تعديل فاتورة الشراء!');
}

